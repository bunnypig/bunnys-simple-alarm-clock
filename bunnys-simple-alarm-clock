).grid(row=0, column=0, padx=5)

tk.Button(
    button_frame,
    bg=BG,
    fg=FG,
    text="Disable All",
    command=disable_all_alarms
).grid(row=0, column=1, padx=5)

tk.Button(
    button_frame,
    bg=BG,
    fg=FG,
    text="Add alarm",
    command=lambda: edit_alarm()
).grid(row=0, column=2, padx=5)

tk.Button(
    button_frame,
    bg=BG,
    fg=FG,
    text="Delete alarm",
    command=delete_alarm
).grid(row=0, column=3, padx=5)

tk.Button(
    button_frame,
    bg=BG,
    fg=FG,
    text="+",
    width=4,
    command=lambda: shift_all_alarms(1)
).grid(row=0, column=4, padx=(5))

tk.Label(
    button_frame,
    bg=BG,
    fg=FG,
    text="Hour",
    font=("Sans", 11, "bold")
).grid(row=0, column=5, padx=5)

tk.Button(
    button_frame,
    bg=BG,
    fg=FG,
    text="-",
    width=4,
    command=lambda: shift_all_alarms(-1)
).grid(row=0, column=6, padx=5)

tk.Button(
    button_frame,
    bg=BG,
    fg=FG,
    text="+",
    width=4,
    command=lambda: shift_selected_alarm_minutes(15)
).grid(row=1, column=4, padx=(20, 5), pady=5)

tk.Label(
    button_frame,
    bg=BG,
    fg=FG,
    text="15 min",
    font=("Sans", 11, "bold")
).grid(row=1, column=5, padx=5, pady=5)

tk.Button(
    button_frame,
    bg=BG,
    fg=FG,
    text="-",
    width=4,
    command=lambda: shift_selected_alarm_minutes(-15)
).grid(row=1, column=6, padx=5, pady=5)

tk.Button(
    button_frame,
    bg=BG,
    fg=FG,
    text="Stop Alarm",
    command=stop_alarm
).grid(row=0, column=7, padx=5)

status_label = tk.Label(root, bg=BG, fg=FG, text="No alarm ringing", font=("Sans", 12))
status_label.pack(pady=8)

load()
check_alarms()
update_countdowns()

root.mainloop()
